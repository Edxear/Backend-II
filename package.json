    "multer": "^1.4.5-lts.1",
    "node": "^25.5.0",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "socket.io": "^4.7.2",
    "twilio": "^5.12.2"
