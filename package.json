    "lint:fix": "eslint src public/js --fix",
    "format": "prettier --write \"src/**/*.js\" \"public/js/**/*.js\" \"public/css/**/*.css\"",
    "format:check": "prettier --check \"src/**/*.js\" \"public/js/**/*.js\" \"public/css/**/*.css\"",
    "format:phase": "prettier --write \"src/app.js\" \"src/config/config.js\" \"src/middleware/**/*.js\" \"src/routes/**/*.js\" \"src/views/login.handlebars\" \"src/views/register.handlebars\" \"tests/**/*.js\" \".github/workflows/*.yml\"",
    "format:phase:check": "prettier --check \"src/app.js\" \"src/config/config.js\" \"src/middleware/**/*.js\" \"src/routes/**/*.js\" \"src/views/login.handlebars\" \"src/views/register.handlebars\" \"tests/**/*.js\" \".github/workflows/*.yml\""
  },
