# Environment variables
## Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net
DB_NAME=integrative_practice

## Server
PORT=8083
NODE_ENV=development

## JWT Secret
JWT_SECRET=your_super_secure_jwt_secret_key_change_this_in_production

## Session & Cookies
SESSION_SECRET=your_session_secret_key
COOKIE_SECRET=your_cookie_secret_key

## GitHub OAuth (Opcional)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8083/api/sessions/github/callback

## Twilio SMS (Opcional)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SMS_NUMBER=your_twilio_phone_number

## Email (Gmail)
## Instrucciones en GMAIL_SETUP.md
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_SERVICE=gmail

## Security
CORS_ORIGIN=http://localhost:8083
