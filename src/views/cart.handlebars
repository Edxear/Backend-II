<div class="w-full max-w-3xl mx-auto px-4 pt-8 pb-12">

    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
        <h1 class="font-display text-3xl font-bold text-indigo-900">Mi Carrito</h1>
        <a href="/" class="text-indigo-600 hover:text-indigo-800 font-semibold text-sm transition-colors">← Volver al catálogo</a>
    </div>

    {{#if products.length}}
        <!-- Cart items -->
        <div class="bg-white rounded-2xl border border-indigo-100 shadow-md overflow-hidden mb-6">
            {{#each products}}
                <div class="flex items-center justify-between gap-4 px-6 py-5 {{#unless @last}}border-b border-slate-100{{/unless}}">
                    <div class="flex-1 min-w-0">
                        <h3 class="font-display font-bold text-indigo-950 truncate">{{this.product.title}}</h3>
                        <p class="text-slate-400 text-sm mt-0.5 font-semibold uppercase tracking-wide">{{this.product.category}}</p>
                    </div>
                    <div class="text-right shrink-0">
                        <p class="text-lg font-extrabold text-indigo-700">ARS {{this.product.price}}</p>
                        <p class="text-sm text-slate-500 font-semibold">Cantidad: {{this.quantity}}</p>
                    </div>
                </div>
            {{/each}}
        </div>

        <!-- Actions -->
        <div class="flex gap-3 justify-end">
            <a href="/" class="bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold px-5 py-2.5 rounded-xl text-sm transition-colors">
                Seguir comprando
            </a>
        </div>
    {{else}}
        <!-- Empty cart -->
        <div class="text-center bg-white/70 border border-indigo-100 rounded-2xl p-12 shadow">
            <p class="text-6xl mb-4">🛒</p>
            <h3 class="font-display text-xl font-bold text-indigo-900 mb-2">Tu carrito está vacío</h3>
            <p class="text-slate-500 mb-6">Agregá productos desde el catálogo.</p>
            <a href="/" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-6 py-3 rounded-xl text-sm transition-colors">
                Ver catálogo
            </a>
        </div>
    {{/if}}

</div>