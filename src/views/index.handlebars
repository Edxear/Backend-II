<div class="box">
    <div class="header">
        <div class="navbar">
            <h1>Tienda Nova</h1>
            <div class="nav-buttons">
                {{#if isLoggedIn}}
                    <div class="user-info">
                        <span class="user-greeting">{{user.first_name}} {{user.last_name}}</span>
                        <a id="button-cart" href="#" class="button button-primary hidden-cart">Ver Carrito</a>
                        <a href="/current" class="button button-secondary">Perfil</a>
                        <form id="logoutForm" style="display: inline;">
                            <button type="submit" class="button button-danger">Salir</button>
                        </form>
                    </div>
                {{else}}
                    <div class="auth-buttons">
                        <a href="/login" class="button button-primary">Iniciar Sesión</a>
                        <a href="/register" class="button button-secondary">Registrarse</a>
                    </div>
                {{/if}}
            </div>
        </div>
    </div>

    <section class="hero">
        <p class="hero-kicker">Coleccion destacada</p>
        <h2>Catalogo de Productos</h2>
        <p class="hero-subtitle">Descubri tecnologia, hogar y estilo con envios rapidos y precios actualizados.</p>
    </section>

    {{#if products.length}}
        <div class="products-box">
            {{#each products}}
                <div class="product-card">
                    <img class="product-image" src="{{this.imageUrl}}" alt="Imagen de {{this.title}}" loading="lazy">
                    <h3>{{this.title}}</h3>
                    <hr>
                    <p><strong>Categoría:</strong> {{this.category}}</p>
                    <p><strong>Descripción:</strong> {{this.description}}</p>
                    <p><strong>Precio:</strong> <span class="price">ARS {{this.formattedPrice}}</span></p>
                    <p><strong>Stock:</strong> <span class="stock">{{this.stock}} unidades</span></p>
                    
                    {{#if ../isLoggedIn}}
                        <button class="button button-success" onclick="addToCart('{{this._id}}')">
                            Agregar al Carrito
                        </button>
                    {{else}}
                        <button class="button button-secondary" onclick="requireLogin()">
                            Agregar al Carrito (requiere login)
                        </button>
                    {{/if}}
                </div>
            {{/each}}
        </div>
    {{else}}
        <div class="no-products">
            <h3>Estamos preparando tu catalogo</h3>
            <p>No hay productos disponibles por el momento. Carga el seed para visualizar la tienda con contenido.</p>
            <p class="no-products-hint">Comando: npm run seed:products</p>
        </div>
    {{/if}}

    <div class="footer">
        {{#if prevLink.exist}}
            <a class="button button-paginate" href="{{prevLink.link}}">← Anterior</a>
        {{/if}}
        {{#if nextLink.exist}}
            <a class="button button-paginate" href="{{nextLink.link}}">Siguiente →</a>
        {{/if}}
    </div>
</div>

<script>
    document.getElementById('logoutForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();

        try {
            const response = await fetch('/api/sessions/logout', {
                method: 'POST'
            });

            if (response.ok) {
                window.location.href = '/';
            }
        } catch (error) {
            console.error('Error:', error);
        }
    });

    function addToCart(productId) {
        window.addToCart(productId);
    }

    function requireLogin() {
        alert('Por favor inicia sesión para agregar productos al carrito');
        window.location.href = '/login';
    }
</script>
<script src="/js/ecommerce.js"></script>