                    </article>
                    <article class="product-zoom-card border border-slate-200 rounded-[6px] overflow-hidden bg-white hover:shadow-md transition-shadow touch-manipulation">
                        <img src="https://images.pexels.com/photos/1456735/pexels-photo-1456735.jpeg?auto=compress&cs=tinysrgb&w=700" alt="Sneakers Air Flex" loading="lazy" class="product-zoom-media w-full aspect-square object-cover">
                        <div class="p-3">
                            <p class="text-xs text-slate-500 line-clamp-2 min-h-[2rem]">Sneakers Air Flex</p>
                            <p class="text-xs text-slate-400 line-through mt-1">ARS 167.721</p>
                            <p class="text-[23px] leading-none font-light text-slate-900 mt-1">ARS 132.499</p>
                            <p class="text-xs font-semibold text-emerald-600 mt-1">21% OFF</p>
                            <button class="mt-3 w-full bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2 rounded">Ver oferta</button>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <section id="catalogo-completo" class="bg-white rounded-[6px] shadow-sm border border-slate-200 p-4 md:p-5 mb-8 scroll-mt-6">
            <div class="flex items-center justify-between mb-5 gap-3">
                <h2 class="text-[26px] leading-none font-light text-slate-800">Catalogo completo</h2>
                <span class="text-xs text-slate-500">Pagina {{pagination.page}} de {{pagination.totalPages}}</span>
            </div>

            {{#if products.length}}
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                {{#each products}}
                <article class="product-zoom-card border border-slate-200 rounded-[6px] overflow-hidden bg-white hover:shadow-md transition-shadow touch-manipulation">
                    <img src="{{this.imageUrl}}" alt="{{this.title}}" loading="lazy" class="product-zoom-media w-full aspect-square object-cover">
                    <div class="p-3">
                        <p class="text-[11px] uppercase tracking-wide text-slate-400">{{this.category}}</p>
                        <p class="text-sm text-slate-700 line-clamp-2 min-h-[2.5rem] mt-1">{{this.title}}</p>
                        <p class="text-[23px] leading-none font-light text-slate-900 mt-2">ARS {{this.formattedPrice}}</p>
                        <p class="text-xs text-slate-400 mt-1">{{this.stock}} en stock</p>
                        {{#if ../isLoggedIn}}
                        <button onclick="addToCart('{{this._id}}')" class="mt-3 w-full bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2 rounded">Agregar al carrito</button>
                        {{else}}
                        <button onclick="requireLogin()" class="mt-3 w-full bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-bold py-2 rounded border border-slate-200">Iniciar sesion para comprar</button>
                        {{/if}}
                    </div>
                </article>
                {{/each}}
            </div>
            {{else}}
            <div class="text-center py-10">
                <p class="text-4xl">🛒</p>
                <p class="text-slate-500 mt-3">No hay productos disponibles por el momento.</p>
                <p class="text-xs text-slate-400 mt-2">Comando sugerido: npm run seed:products</p>
            </div>
            {{/if}}

            <div class="flex flex-col md:flex-row items-center justify-between gap-3 mt-7 border-t border-slate-100 pt-4">
                <p class="text-xs text-slate-500">Navega por el catalogo sin perder esta seccion.</p>
                <div class="flex justify-center gap-3">
                {{#if prevLink.exist}}
                <a href="{{prevLink.link}}#catalogo-completo" class="bg-white hover:bg-slate-50 text-slate-700 font-bold px-5 py-2 rounded text-sm border border-slate-300">Anterior</a>
                {{/if}}
                {{#if nextLink.exist}}
                <a href="{{nextLink.link}}#catalogo-completo" class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-5 py-2 rounded text-sm">Siguiente</a>
                {{/if}}
                </div>
            </div>
        </section>
    </main>

    <footer class="mt-8 bg-white border-t border-slate-200">
        <div class="max-w-[1200px] mx-auto px-3 sm:px-4 py-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <h4 class="text-sm font-bold text-slate-800 mb-2">Compras seguras</h4>
                    <p class="text-xs text-slate-500 leading-relaxed">Proteccion al comprador, pagos seguros y seguimiento de tus pedidos en todo momento.</p>
                </div>
                <div>
                    <h4 class="text-sm font-bold text-slate-800 mb-2">Atencion al cliente</h4>
                    <ul class="space-y-1 text-xs text-slate-500">
                        <li><a href="/products" class="hover:underline">Centro de ayuda</a></li>
                        <li><a href="/products" class="hover:underline">Cambios y devoluciones</a></li>
                        <li><a href="/products" class="hover:underline">Contacto</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-sm font-bold text-slate-800 mb-2">Navegacion</h4>
                    <ul class="space-y-1 text-xs text-slate-500">
                        <li><a href="#ofertas-dia" class="hover:underline">Ofertas del dia</a></li>
                        <li><a href="#mas-vendidos" class="hover:underline">Mas vendidos</a></li>
                        <li><a href="/products" class="hover:underline">Catalogo completo</a></li>
                    </ul>
                </div>
            </div>
            <div class="mt-6 pt-4 border-t border-slate-100 text-[11px] text-slate-400 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
                <p>Copyright © 2026 Tienda Nova.</p>
                <p>Hecho para practica de e-commerce con Node.js y Handlebars.</p>
            </div>
        </div>
    </footer>
</div>

<script>
    document.getElementById('logoutForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        try {
            const res = await fetch('/api/sessions/logout', { method: 'POST' });
            if (res.ok) window.location.href = '/';
        } catch (err) { console.error(err); }
    });

    const heroSlides = Array.from(document.querySelectorAll('.hero-slide'));
    const heroDots = Array.from(document.querySelectorAll('.hero-dot'));
    let heroIndex = 0;
    let heroTimer = null;

    function renderHeroSlide(nextIndex) {
        heroSlides.forEach((slide, idx) => {
            const isActive = idx === nextIndex;
            slide.classList.toggle('opacity-100', isActive);
            slide.classList.toggle('opacity-0', !isActive);
            slide.classList.toggle('pointer-events-none', !isActive);
        });

        heroDots.forEach((dot, idx) => {
            const isActive = idx === nextIndex;
            dot.classList.toggle('w-2.5', isActive);
            dot.classList.toggle('h-2.5', isActive);
            dot.classList.toggle('w-2', !isActive);
            dot.classList.toggle('h-2', !isActive);
            dot.classList.toggle('bg-white', isActive);
            dot.classList.toggle('bg-white/55', !isActive);
        });

        heroIndex = nextIndex;
    }

    function startHeroAutoplay() {
        if (heroSlides.length <= 1) return;
        heroTimer = setInterval(() => {
            const next = (heroIndex + 1) % heroSlides.length;
            renderHeroSlide(next);
        }, 4500);
    }

    if (heroSlides.length && heroDots.length) {
        heroDots.forEach((dot, idx) => {
            dot.addEventListener('click', () => {
                renderHeroSlide(idx);
                if (heroTimer) {
                    clearInterval(heroTimer);
                    startHeroAutoplay();
                }
            });
        });

        renderHeroSlide(0);
        startHeroAutoplay();
    }

    const catSlides = Array.from(document.querySelectorAll('.cat-slide'));
    const catPrev = document.getElementById('cat-prev');
    const catNext = document.getElementById('cat-next');
    const catDotsDesktop = document.getElementById('cat-dots-desktop');
    const catDotsMobile = document.getElementById('cat-dots-mobile');
    let catIndex = 0;

    function buildCatDots(container) {
        if (!container) return [];
        container.innerHTML = '';
        return catSlides.map((_, idx) => {
            const dot = document.createElement('button');
            dot.type = 'button';
            dot.className = idx === 0 ? 'h-2 w-2 rounded-full bg-blue-500' : 'h-2 w-2 rounded-full bg-slate-300';
            dot.setAttribute('aria-label', `Slide categorias ${idx + 1}`);
            dot.addEventListener('click', () => showCatSlide(idx));
            container.appendChild(dot);
            return dot;
        });
    }

    const catDotButtonsDesktop = buildCatDots(catDotsDesktop);
    const catDotButtonsMobile = buildCatDots(catDotsMobile);

    function showCatSlide(nextIndex) {
        catSlides.forEach((slide, idx) => {
            const isActive = idx === nextIndex;
            slide.classList.toggle('block', isActive);
            slide.classList.toggle('hidden', !isActive);
        });

        [...catDotButtonsDesktop, ...catDotButtonsMobile].forEach((dot, idx) => {
            dot.classList.toggle('bg-blue-500', idx === nextIndex);
            dot.classList.toggle('bg-slate-300', idx !== nextIndex);
        });

        catIndex = nextIndex;
    }

    catPrev?.addEventListener('click', () => {
        const next = (catIndex - 1 + catSlides.length) % catSlides.length;
        showCatSlide(next);
    });

    catNext?.addEventListener('click', () => {
        const next = (catIndex + 1) % catSlides.length;
        showCatSlide(next);
    });

    if (catSlides.length) showCatSlide(0);

    function requireLogin() {
        if (confirm('Necesitas iniciar sesion para agregar productos al carrito. Ir a login?')) {
            window.location.href = '/login';
        }
    }
</script>
<script src="/js/ecommerce.js"></script>
