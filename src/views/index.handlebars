<div class="w-full bg-[#ebebeb] pb-12">
    <header class="w-full bg-[#fff159] border-b border-[#e9dc5e] shadow-[0_1px_0_rgba(0,0,0,0.08)]">
        <div class="max-w-7xl mx-auto px-4 py-2.5">
            <div class="grid grid-cols-1 lg:grid-cols-[170px_1fr_300px] gap-2.5 items-center">
                <a href="/" class="flex items-center gap-2 text-[#333]">
                    <span class="h-9 w-9 rounded-full bg-[#3483fa] text-white flex items-center justify-center font-black text-sm">TN</span>
                    <div class="leading-tight">
                        <p class="font-black text-[22px] tracking-tight">tienda</p>
                        <p class="text-[10px] uppercase tracking-[0.25em] font-bold -mt-1">nova</p>
                    </div>
                </a>

                <div class="relative">
                    <input type="text"
                           placeholder="Buscar productos, marcas y mas..."
                           class="w-full h-10 rounded-[2px] border border-[#eee] bg-white px-4 pr-12 text-[16px] text-[#666] shadow-[0_1px_2px_rgba(0,0,0,0.08)] focus:outline-none focus:ring-2 focus:ring-blue-300">
                    <span class="absolute right-0 top-0 h-10 w-11 border-l border-[#eee] text-[#999] flex items-center justify-center text-base">⌕</span>
                </div>

                <div class="hidden lg:flex justify-end">
                    <div class="bg-[#2d3277] text-white rounded-full px-4 py-1.5 text-[13px] font-bold tracking-wide">ENVIO GRATIS EN TU PRIMERA COMPRA</div>
                </div>
            </div>

            <div class="mt-2 flex flex-col lg:flex-row lg:items-center lg:justify-between gap-2 text-[14px] text-[#666]">
                <div class="flex items-center gap-2">
                    <span class="text-lg">⌖</span>
                    <div class="leading-tight">
                        <p class="text-[11px] text-[#888]">Enviar a</p>
                        <p class="font-semibold text-[#333]">Argentina 2820</p>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-4 text-[#666]">
                    <a href="/products" class="hover:text-[#333]">Categorias</a>
                    <a href="#ofertas-dia" class="hover:text-[#333]">Ofertas</a>
                    <a href="#mas-vendidos" class="hover:text-[#333]">Mas vendidos</a>
                    <a href="/products" class="hover:text-[#333]">Supermercado</a>
                    <a href="/products" class="hover:text-[#333]">Moda</a>
                    <a href="/products" class="hover:text-[#333]">Ayuda</a>
                </div>

                <div class="flex flex-wrap items-center gap-4">
                    {{#if isLoggedIn}}
                        <span class="font-semibold text-[#333]">{{user.first_name}} {{user.last_name}}</span>
                        <a href="/current" class="hover:text-[#333]">Perfil</a>
                        <a id="button-cart" href="#" class="hidden relative items-center gap-2 hover:text-[#333] font-semibold">
                            Carrito
                            <span id="cart-badge" class="hidden absolute -top-2 -right-3 h-5 min-w-5 px-1 bg-red-500 text-white text-[10px] font-bold rounded-full items-center justify-center">0</span>
                        </a>
                        <form id="logoutForm" style="display:inline;">
                            <button type="submit" class="font-semibold hover:text-[#333]">Salir</button>
                        </form>
                    {{else}}
                        <a href="/register" class="hover:text-[#333]">Crea tu cuenta</a>
                        <a href="/login" class="hover:text-[#333] font-semibold">Ingresa</a>
                    {{/if}}
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4">
        <section id="hero-carousel" class="relative mt-4 rounded-md overflow-hidden bg-[#ffe600] min-h-[280px] md:min-h-[360px] shadow">
            <article class="hero-slide absolute inset-0 opacity-100 transition-opacity duration-700">
                <div class="absolute inset-0 bg-gradient-to-r from-[#ffe600] via-[#ffea00] to-[#ffef5f]"></div>
                <div class="relative h-full px-7 md:px-12 py-9 flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="max-w-xl text-slate-900">
                        <p class="text-sm font-bold uppercase tracking-[0.2em] text-slate-700">Promo destacada</p>
                        <h1 class="font-black leading-[0.95] text-4xl md:text-6xl mt-1">ENVIO GRATIS</h1>
                        <p class="font-extrabold text-2xl md:text-4xl mt-1">EN TU PRIMERA COMPRA*</p>
                        <p class="text-sm mt-4 text-slate-700">*Consulte terminos y condiciones.</p>
                    </div>
                    <img src="https://images.pexels.com/photos/4246120/pexels-photo-4246120.jpeg?auto=compress&cs=tinysrgb&w=700"
                         alt="Caja de envio sobre mesa"
                         class="w-[240px] h-[170px] md:w-[360px] md:h-[250px] rounded-md object-cover shadow-2xl border border-black/10">
                </div>
            </article>

            <article class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-700 pointer-events-none">
                <div class="absolute inset-0 bg-gradient-to-r from-[#f8d90f] via-[#ffe26d] to-[#fff1a0]"></div>
                <div class="relative h-full px-7 md:px-12 py-9 flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="max-w-xl text-slate-900">
                        <p class="text-sm font-bold uppercase tracking-[0.2em] text-slate-700">Semana de tecnologia</p>
                        <h1 class="font-black leading-[0.95] text-4xl md:text-6xl mt-1">HASTA 35% OFF</h1>
                        <p class="font-extrabold text-2xl md:text-4xl mt-1">EN CELULARES Y NOTEBOOKS</p>
                        <p class="text-sm mt-4 text-slate-700">Ofertas por tiempo limitado.</p>
                    </div>
                    <img src="https://images.pexels.com/photos/699122/pexels-photo-699122.jpeg?auto=compress&cs=tinysrgb&w=700"
                         alt="Dispositivos electronicos"
                         class="w-[240px] h-[170px] md:w-[360px] md:h-[250px] rounded-md object-cover shadow-2xl border border-black/10">
                </div>
            </article>

            <article class="hero-slide absolute inset-0 opacity-0 transition-opacity duration-700 pointer-events-none">
                <div class="absolute inset-0 bg-gradient-to-r from-[#ffe600] via-[#fff06a] to-[#f4d90d]"></div>
                <div class="relative h-full px-7 md:px-12 py-9 flex flex-col md:flex-row items-center justify-between gap-6">
                    <div class="max-w-xl text-slate-900">
                        <p class="text-sm font-bold uppercase tracking-[0.2em] text-slate-700">Vuelta al cole</p>
                        <h1 class="font-black leading-[0.95] text-4xl md:text-6xl mt-1">CUOTAS SIN INTERES</h1>
                        <p class="font-extrabold text-2xl md:text-4xl mt-1">EN PRODUCTOS SELECCIONADOS</p>
                        <p class="text-sm mt-4 text-slate-700">Aprovecha hoy para equiparte.</p>
                    </div>
                    <img src="https://images.pexels.com/photos/5797910/pexels-photo-5797910.jpeg?auto=compress&cs=tinysrgb&w=700"
                         alt="Compras y productos de oficina"
                         class="w-[240px] h-[170px] md:w-[360px] md:h-[250px] rounded-md object-cover shadow-2xl border border-black/10">
                </div>
            </article>

            <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex gap-2 z-10">
                <button type="button" class="hero-dot w-2.5 h-2.5 rounded-full bg-white" aria-label="Slide 1"></button>
                <button type="button" class="hero-dot w-2 h-2 rounded-full bg-white/55 mt-[1px]" aria-label="Slide 2"></button>
                <button type="button" class="hero-dot w-2 h-2 rounded-full bg-white/55 mt-[1px]" aria-label="Slide 3"></button>
            </div>
        </section>

        <section class="-mt-6 md:-mt-8 relative z-10 mb-8">
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
                <article class="rounded-md bg-[#ededed] border border-slate-200 p-4 shadow-sm">
                    <p class="font-bold text-slate-800 mb-2">Envio gratis</p>
                    <p class="text-xs text-slate-500">Beneficio por ser tu primera compra.</p>
                </article>
                <article class="rounded-md bg-[#ededed] border border-slate-200 p-4 shadow-sm">
                    <p class="font-bold text-slate-800 mb-2">Ingresa a tu cuenta</p>
                    <p class="text-xs text-slate-500">Disfruta de ofertas y compra sin limites.</p>
                </article>
                <article class="rounded-md bg-[#ededed] border border-slate-200 p-4 shadow-sm">
                    <p class="font-bold text-slate-800 mb-2">Ingresa tu ubicacion</p>
                    <p class="text-xs text-slate-500">Consulta costos y tiempos de entrega.</p>
                </article>
                <article class="rounded-md bg-[#ededed] border border-slate-200 p-4 shadow-sm">
                    <p class="font-bold text-slate-800 mb-2">Medios de pago</p>
                    <p class="text-xs text-slate-500">Paga tus compras de forma rapida y segura.</p>
                </article>
                <article class="rounded-md bg-[#ededed] border border-slate-200 p-4 shadow-sm">
                    <p class="font-bold text-slate-800 mb-2">Menos de $20.000</p>
                    <p class="text-xs text-slate-500">Descubri productos con precios bajos.</p>
                </article>
                <article class="rounded-md bg-[#ededed] border border-slate-200 p-4 shadow-sm">
                    <p class="font-bold text-slate-800 mb-2">Mas vendidos</p>
                    <p class="text-xs text-slate-500">Explora los productos tendencia.</p>
                </article>
            </div>
        </section>

        <section id="ofertas-dia" class="bg-white rounded-md shadow-sm border border-slate-200 p-4 md:p-5 mb-8">
            <div class="flex items-center justify-between mb-4 gap-3">
                <h2 class="text-2xl font-light text-slate-800">Ofertas del dia</h2>
                <a href="/products" class="text-sm text-blue-600 hover:underline">Ver todas</a>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-3">
                {{#each deals}}
                <article class="border border-slate-200 rounded-md overflow-hidden hover:shadow-lg transition-shadow bg-white">
                    <div class="relative">
                        <img src="{{this.imageUrl}}" alt="{{this.title}}" loading="lazy" class="w-full aspect-square object-cover">
                        <span class="absolute top-2 left-2 bg-[#ff7733] text-white text-[10px] font-bold px-2 py-1 rounded">{{this.discountPct}}% OFF</span>
                    </div>
                    <div class="p-3">
                        <p class="text-xs text-slate-400 line-through">ARS {{this.originalFormattedPrice}}</p>
                        <p class="text-xl font-light text-slate-900 leading-none mt-1">ARS {{this.formattedPrice}}</p>
                        <p class="text-xs text-emerald-600 mt-1 font-semibold">{{this.discountPct}}% OFF</p>
                        {{#if this.freeShipping}}
                        <p class="text-xs text-emerald-600 mt-1">Envio gratis</p>
                        {{/if}}
                        <p class="text-xs text-slate-500 mt-2 line-clamp-2 min-h-[2rem]">{{this.title}}</p>
                        {{#if ../isLoggedIn}}
                        <button onclick="addToCart('{{this._id}}')" class="mt-3 w-full bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2 rounded">Agregar</button>
                        {{else}}
                        <button onclick="requireLogin()" class="mt-3 w-full bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-bold py-2 rounded border border-slate-200">Ver oferta</button>
                        {{/if}}
                    </div>
                </article>
                {{/each}}
            </div>
        </section>

        <section id="mas-vendidos" class="bg-white rounded-md shadow-sm border border-slate-200 p-4 md:p-5 mb-8">
            <div class="flex items-center justify-between mb-5 gap-3">
                <h2 class="text-2xl font-light text-slate-800">Mas vendidos</h2>
                <a href="/products" class="text-sm text-blue-600 hover:underline">Ver mas</a>
            </div>

            {{#each categoryGroups}}
            <div class="mb-6 last:mb-0">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-slate-700 text-sm md:text-base">{{this.icon}} {{this.name}}</h3>
                    <a href="/products?category={{this.name}}" class="text-xs text-blue-600 hover:underline">Ver categoria</a>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                    {{#each this.products}}
                    <article class="border border-slate-200 rounded-md overflow-hidden bg-white hover:shadow-md transition-shadow">
                        <img src="{{this.imageUrl}}" alt="{{this.title}}" loading="lazy" class="w-full aspect-square object-cover">
                        <div class="p-3">
                            <p class="text-xs text-slate-500 line-clamp-2 min-h-[2rem]">{{this.title}}</p>
                            <p class="text-lg font-light text-slate-900 mt-1">ARS {{this.formattedPrice}}</p>
                            <p class="text-xs text-slate-400 mt-1">{{this.stock}} disponibles</p>
                            {{#if ../../isLoggedIn}}
                            <button onclick="addToCart('{{this._id}}')" class="mt-3 w-full bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2 rounded">Agregar</button>
                            {{else}}
                            <button onclick="requireLogin()" class="mt-3 w-full bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-bold py-2 rounded border border-slate-200">Ver</button>
                            {{/if}}
                        </div>
                    </article>
                    {{/each}}
                </div>
            </div>
            {{/each}}
        </section>

        <section class="bg-white rounded-md shadow-sm border border-slate-200 p-4 md:p-5 mb-8">
            <div class="flex items-center justify-between mb-5 gap-3">
                <h2 class="text-2xl font-light text-slate-800">Catalogo completo</h2>
                <span class="text-xs text-slate-500">Paginado</span>
            </div>

            {{#if products.length}}
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                {{#each products}}
                <article class="border border-slate-200 rounded-md overflow-hidden bg-white hover:shadow-md transition-shadow">
                    <img src="{{this.imageUrl}}" alt="{{this.title}}" loading="lazy" class="w-full aspect-square object-cover">
                    <div class="p-3">
                        <p class="text-[11px] uppercase tracking-wide text-slate-400">{{this.category}}</p>
                        <p class="text-sm text-slate-700 line-clamp-2 min-h-[2.5rem] mt-1">{{this.title}}</p>
                        <p class="text-lg font-light text-slate-900 mt-2">ARS {{this.formattedPrice}}</p>
                        <p class="text-xs text-slate-400 mt-1">{{this.stock}} en stock</p>
                        {{#if ../isLoggedIn}}
                        <button onclick="addToCart('{{this._id}}')" class="mt-3 w-full bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold py-2 rounded">Agregar al carrito</button>
                        {{else}}
                        <button onclick="requireLogin()" class="mt-3 w-full bg-slate-100 hover:bg-slate-200 text-slate-700 text-xs font-bold py-2 rounded border border-slate-200">Iniciar sesion para comprar</button>
                        {{/if}}
                    </div>
                </article>
                {{/each}}
            </div>
            {{else}}
            <div class="text-center py-10">
                <p class="text-4xl">🛒</p>
                <p class="text-slate-500 mt-3">No hay productos disponibles por el momento.</p>
                <p class="text-xs text-slate-400 mt-2">Comando sugerido: npm run seed:products</p>
            </div>
            {{/if}}

            <div class="flex justify-center gap-3 mt-7">
                {{#if prevLink.exist}}
                <a href="{{prevLink.link}}" class="bg-slate-700 hover:bg-slate-800 text-white font-bold px-5 py-2 rounded text-sm">Anterior</a>
                {{/if}}
                {{#if nextLink.exist}}
                <a href="{{nextLink.link}}" class="bg-slate-700 hover:bg-slate-800 text-white font-bold px-5 py-2 rounded text-sm">Siguiente</a>
                {{/if}}
            </div>
        </section>
    </main>
</div>

<script>
    document.getElementById('logoutForm')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        try {
            const res = await fetch('/api/sessions/logout', { method: 'POST' });
            if (res.ok) window.location.href = '/';
        } catch (err) { console.error(err); }
    });

    const heroSlides = Array.from(document.querySelectorAll('.hero-slide'));
    const heroDots = Array.from(document.querySelectorAll('.hero-dot'));
    let heroIndex = 0;
    let heroTimer = null;

    function renderHeroSlide(nextIndex) {
        heroSlides.forEach((slide, idx) => {
            const isActive = idx === nextIndex;
            slide.classList.toggle('opacity-100', isActive);
            slide.classList.toggle('opacity-0', !isActive);
            slide.classList.toggle('pointer-events-none', !isActive);
        });

        heroDots.forEach((dot, idx) => {
            const isActive = idx === nextIndex;
            dot.classList.toggle('w-2.5', isActive);
            dot.classList.toggle('h-2.5', isActive);
            dot.classList.toggle('w-2', !isActive);
            dot.classList.toggle('h-2', !isActive);
            dot.classList.toggle('bg-white', isActive);
            dot.classList.toggle('bg-white/55', !isActive);
        });

        heroIndex = nextIndex;
    }

    function startHeroAutoplay() {
        if (heroSlides.length <= 1) return;
        heroTimer = setInterval(() => {
            const next = (heroIndex + 1) % heroSlides.length;
            renderHeroSlide(next);
        }, 4500);
    }

    if (heroSlides.length && heroDots.length) {
        heroDots.forEach((dot, idx) => {
            dot.addEventListener('click', () => {
                renderHeroSlide(idx);
                if (heroTimer) {
                    clearInterval(heroTimer);
                    startHeroAutoplay();
                }
            });
        });

        renderHeroSlide(0);
        startHeroAutoplay();
    }

    function requireLogin() {
        if (confirm('Necesitas iniciar sesion para agregar productos al carrito. Ir a login?')) {
            window.location.href = '/login';
        }
    }
</script>
<script src="/js/ecommerce.js"></script>
