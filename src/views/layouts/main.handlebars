<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{title}}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap" rel="stylesheet">
        <script src="https://cdn.tailwindcss.com"></script>
        <script>
            tailwind.config = {
                theme: {
                    extend: {
                        fontFamily: {
                            display: ['Fraunces', 'Georgia', 'serif'],
                            body: ['Manrope', '"Segoe UI"', 'sans-serif'],
                        }
                    }
                }
            }
        </script>
        <link rel="stylesheet" href="/css/{{style}}">
    </head>
    <body class="min-h-screen bg-gradient-to-br from-indigo-50 via-blue-50 to-sky-50 font-body antialiased text-slate-700">

        {{{body}}}

    </body>
</html>