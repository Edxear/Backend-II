{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "src/views/**",
        "public/**",
        "src/data/**"
      ]
    }
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
